{
	"extends": ["next/core-web-vitals", "next/typescript", "prettier"],
	"plugins": ["unused-imports"],
	"rules": {
		"@typescript-eslint/no-explicit-any": "off",
		"unused-imports/no-unused-imports": "error",
		"no-unused-vars": [
			"warn",
			{ "vars": "all", "args": "after-used", "ignoreRestSiblings": true }
		]
	}
}
